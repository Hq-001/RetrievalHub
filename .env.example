# =============================================================================
# RetrievalHub 环境变量配置模板
# 复制为 .env 并填入实际值，.env 不入库
# =============================================================================

# ---- 服务相关 ----
REST_HOST=0.0.0.0
REST_PORT=8000
MCP_TRANSPORT=stdio          # stdio | sse
MCP_SSE_PORT=8001
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ---- 上传限制 ----
MAX_UPLOAD_SIZE_MB=10
MAX_CONCURRENT_UPLOADS=5

# ---- 嵌入模型 ----
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=64

# ---- 重排序模型 ----
RERANKER_ENABLED=true
RERANKER_ENDPOINT=
RERANKER_API_KEY=
RERANKER_MODEL=
RERANKER_TOP_K=20

# ---- 存储 (LanceDB) ----
LANCEDB_URI=./data/lancedb
LANCEDB_DISTANCE_METRIC=cosine

# ---- 元数据库 (SQLite) ----
SQLITE_PATH=./data/metadata.db

# ---- 分块参数 (MD 独立) ----
MD_CHUNK_SIZE=800
MD_CHUNK_OVERLAP=100
MD_MAX_SECTION_DEPTH=3

# ---- 分块参数 (JSON 独立) ----
JSON_CHUNK_SIZE=600
JSON_CHUNK_OVERLAP=60
JSON_LONG_VALUE_THRESHOLD=2000

# ---- 检索参数 ----
VECTOR_RECALL_TOP_N=50
BM25_RECALL_TOP_N=50
RERANK_TOP_K=10

# ---- 动态加权 ----
MD_VECTOR_WEIGHT=1.1
JSON_BM25_WEIGHT=1.2

# ---- 异步入库 ----
INGEST_TIMEOUT_SEC=30

# ---- 热点查询 LRU 缓存 ----
QUERY_CACHE_MAXSIZE=512
QUERY_CACHE_TTL_SEC=300

# ---- 存储加密 ----
ENABLE_STORAGE_ENCRYPTION=false
STORAGE_ENCRYPTION_KEY=

# ---- MCP 超时与重试 ----
MCP_SEARCH_TIMEOUT_MS=5000

# ---- 鉴权 ----
API_KEY=
